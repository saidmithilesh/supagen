{
  "name": "supagen",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:web:local": "pnpm --filter @supagen/web build:local",
    "build:web:production": "pnpm --filter @supagen/web build:production",
    "lint": "turbo lint",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:watch": "turbo test:watch",
    "typecheck": "turbo typecheck",
    "prepare": "husky",
    "precommit": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "infra:up": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml down",
    "infra:logs": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml logs -f",
    "infra:ps": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml ps",
    "infra:reset": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml down -v",
    "infra:telemetry:up": "mkdir -p .runtime/logs && docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml --profile telemetry up -d loki tempo alloy grafana",
    "infra:telemetry:down": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml --profile telemetry stop loki tempo alloy grafana && docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml --profile telemetry rm -f loki tempo alloy grafana",
    "infra:telemetry:logs": "docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml --profile telemetry logs -f loki tempo alloy grafana",
    "infra:test:up": "docker compose --env-file apps/api/.env.test -f infra/docker-compose.test.yml up -d --wait",
    "infra:test:down": "docker compose --env-file apps/api/.env.test -f infra/docker-compose.test.yml down",
    "infra:test:logs": "docker compose --env-file apps/api/.env.test -f infra/docker-compose.test.yml logs -f",
    "infra:test:ps": "docker compose --env-file apps/api/.env.test -f infra/docker-compose.test.yml ps",
    "telemetry:alloy": "mkdir -p .runtime/logs && docker compose --env-file apps/api/.env.local -f infra/docker-compose.yml --profile telemetry up -d alloy",
    "telemetry:health": "node scripts/runtime-telemetry/health.mjs",
    "telemetry:logs": "node scripts/runtime-telemetry/logs.mjs",
    "telemetry:trace": "node scripts/runtime-telemetry/trace.mjs",
    "test:integration:local": "pnpm infra:test:up && SUPAGEN_API_ENV_FILE=.env.test pnpm db:migrate && pnpm test:integration; exit_code=$?; pnpm infra:test:down; exit $exit_code",
    "db:generate": "pnpm --filter @supagen/api db:generate",
    "db:migrate": "pnpm --filter @supagen/api db:migrate",
    "db:push": "pnpm --filter @supagen/api db:push",
    "db:studio": "pnpm --filter @supagen/api db:studio",
    "db:check": "pnpm --filter @supagen/api db:check"
  },
  "lint-staged": {
    "*.{css,json,md,yaml,yml}": "prettier --write",
    "*.{mjs,cjs,js,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "^3.8.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
