NODE_ENV=test
PORT=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=supagen_test
POSTGRES_USER=supagen
POSTGRES_PASSWORD=supagen_test_password
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

VALKEY_HOST=localhost
VALKEY_PORT=16379
VALKEY_PASSWORD=supagen_test_password
VALKEY_URL=redis://default:${VALKEY_PASSWORD}@${VALKEY_HOST}:${VALKEY_PORT}

CLERK_SECRET_KEY=sk_test_dummy
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

CORS_ALLOWED_ORIGINS=http://localhost:5173

RUNTIME_TELEMETRY_ENABLED=false
RUNTIME_TELEMETRY_LOG_LEVEL=debug
RUNTIME_TELEMETRY_LOG_FORMAT=json
RUNTIME_TELEMETRY_LOG_FILE=
OTEL_SERVICE_NAME=supagen-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
