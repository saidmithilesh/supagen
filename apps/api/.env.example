NODE_ENV=development
PORT=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supagen
POSTGRES_USER=supagen
POSTGRES_PASSWORD=supagen_local_password
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=supagen_local_password
VALKEY_URL=redis://default:${VALKEY_PASSWORD}@${VALKEY_HOST}:${VALKEY_PORT}

CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

CORS_ALLOWED_ORIGINS=http://localhost:5173

RUNTIME_TELEMETRY_ENABLED=true
RUNTIME_TELEMETRY_LOG_LEVEL=debug
RUNTIME_TELEMETRY_LOG_FORMAT=pretty
RUNTIME_TELEMETRY_LOG_FILE=.runtime/logs/api.jsonl
OTEL_SERVICE_NAME=supagen-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
