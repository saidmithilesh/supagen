{
  "name": "@supagen/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --passWithNoTests --config vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "1.4.9",
    "@clerk/ui": "^1.22.0",
    "@supagen/shared": "workspace:*",
    "@supagen/ui": "workspace:*",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/router-plugin": "1.168.18",
    "lucide-react": "1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
