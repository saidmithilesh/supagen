{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "@supagen/ui/*": ["../../packages/ui/src/*"]
    },
    "types": [
      "vite/client",
      "node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "noEmit": true
  },
  "include": ["src", "vite.config.ts", "vitest*.config.ts"]
}
