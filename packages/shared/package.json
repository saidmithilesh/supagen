{
  "name": "@supagen/shared",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --passWithNoTests --config vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.spec.json"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
