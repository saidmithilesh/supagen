{
  "name": "@supagen/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "dev": "tsc --noEmit -p tsconfig.json --watch --preserveWatchOutput",
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --passWithNoTests --config vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clerk/ui": "^1.22.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/material-symbols-outlined": "^5.2.45",
    "@fontsource/be-vietnam-pro": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
